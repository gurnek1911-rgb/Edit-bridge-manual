import { useEffect, useState } from "react";
import { db, auth } from "../../lib/firebase";
import {
  doc,
  getDoc,
  collection,
  addDoc,
  onSnapshot,
  query,
  orderBy
} from "firebase/firestore";
import { useRouter } from "next/router";

export default function Chat() {
  const router = useRouter();
  const { id } = router.query;

  const [messages, setMessages] = useState([]);
  const [msg, setMsg] = useState("");
  const [allowed, setAllowed] = useState(false);

  useEffect(() => {
    if (!id) return;

    const checkAccess = async () => {
      const snap = await getDoc(doc(db, "paymentRequests", id));

      if (snap.exists() && snap.data().status === "approved") {
        setAllowed(true);
      }
    };

    checkAccess();

    const q = query(collection(db, "chats", id, "messages"), orderBy("createdAt"));

    return onSnapshot(q, (snap) => {
      setMessages(snap.docs.map(d => d.data()));
    });

  }, [id]);

  const send = async () => {
    if (!msg) return;

    await addDoc(collection(db, "chats", id, "messages"), {
      text: msg,
      uid: auth.currentUser.uid,
      createdAt: new Date()
    });

    setMsg("");
  };

  if (!allowed) {
    return <div style={{ color: "white" }}>🔒 Chat Locked</div>;
  }

  return (
    <div style={s.page}>
      <div style={s.chat}>
        {messages.map((m, i) => (
          <p key={i}>{m.text}</p>
        ))}
      </div>

      <input value={msg} onChange={(e)=>setMsg(e.target.value)} style={s.input}/>
      <button onClick={send}>Send</button>
    </div>
  );
}

const s = {
  page: { padding: 20, background: "#020617", minHeight: "100vh", color: "white" },
  chat: { height: 400, overflow: "auto" },
  input: { width: "100%", padding: 10 }
};