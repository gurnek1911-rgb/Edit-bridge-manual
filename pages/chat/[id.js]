  page: {
    minHeight: "100vh",
    display: "flex",
    flexDirection: "column",
    background: "linear-gradient(135deg,#020617,#0f172a,#1e1b4b)",
    color: "white",
  },
  centerPage: {
    minHeight: "100vh",
    display: "flex",
    justifyContent: "center",
