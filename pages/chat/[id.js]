    color: "white",
  },
  errorCard: {
    background: "#1e293b",
    padding: 30,
    borderRadius: 12,
    textAlign: "center",
    maxWidth: 340,
  },
  backBtn: {
    marginTop: 16,
    padding: "10px 20px",
    background: "#6366f1",
    color: "white",
    border: "none",
    borderRadius: 10,
    cursor: "pointer",
  },
  header: {
    display: "flex",
    alignItems: "center",
    gap: 10,
    padding: 15,
    borderBottom: "1px solid rgba(255,255,255,0.1)",
  },
  headerTitle: { margin: 0, fontSize: 16, fontWeight: 700 },
  back: {
    background: "none",
    border: "none",
    color: "white",
    fontSize: 22,
    cursor: "pointer",
    padding: "4px 8px",
  },
  chatBox: {
    flex: 1,
    display: "flex",
    flexDirection: "column",
    gap: 10,
    padding: 15,
    overflowY: "auto",
  },
  emptyMsg: { color: "#64748b", textAlign: "center", marginTop: 40 },
  msg: {
    padding: "10px 14px",
    borderRadius: 12,
    maxWidth: "70%",
    fontSize: 14,
    wordBreak: "break-word",
  },
  inputRow: {
    display: "flex",
    padding: 10,
    gap: 8,
    borderTop: "1px solid rgba(255,255,255,0.1)",
  },
  input: {
    flex: 1,
    padding: 10,
    borderRadius: 10,
    border: "1px solid #334155",
    outline: "none",
    background: "#1e293b",
    color: "white",
    fontSize: 14,
  },
  send: {
    padding: "10px 16px",
    background: "#7c3aed",
    border: "none",
